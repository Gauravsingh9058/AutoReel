APP_URL="http://127.0.0.1:4173"
NODE_ENV=development
PORT=4173
HOST=127.0.0.1

GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL=gemini-2.5-flash


PEXELS_API_KEY="YOUR_PEXELS_API_KEY"


USE_POSTGRES=false
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vidsnapai"
REDIS_URL="redis://127.0.0.1:6379"

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
DEFAULT_BACKGROUND_MUSIC_PATH=

STORAGE_MODE=local
STORAGE_BASE_URL=
UPLOADS_DIR=
GENERATED_DIR=
MEDIA_CACHE_DIR=
DATA_DIR=

# Unlimited by default for this workspace. Set ENFORCE_REEL_LIMITS=true and UNLIMITED_REEL_GENERATION=false to enforce FREE_REEL_LIMIT / PRO_REEL_LIMIT.
ENFORCE_REEL_LIMITS=false
UNLIMITED_REEL_GENERATION=true
FREE_REEL_LIMIT=5
PRO_REEL_LIMIT=500

META_APP_ID="YOUR_META_APP_ID"
META_APP_SECRET="YOUR_META_APP_SECRET"
META_REDIRECT_URI="https://your-domain.com/api/instagram/callback"
META_GRAPH_VERSION=v24.0
META_OAUTH_SCOPES="pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish,business_management"

# Backend-only Instagram publishing. Users do not connect Instagram inside the SaaS UI.
# The video still must be hosted at a public HTTPS URL through APP_URL or STORAGE_BASE_URL.
META_ACCESS_TOKEN=
META_IG_USER_ID=
